{
  "name": "renux-project-actions",
  "displayName": "Project Scripts",
  "description": "Execute project scripts from a sidebar panel.",
  "version": "0.3.11",
  "publisher": "renux918",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "scripts",
    "terminal",
    "commands",
    "sidebar",
    "productivity"
  ],
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dantesCode/project-actions"
  },
  "license": "MIT",
  "activationEvents": [
    "onStartup"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectActions",
          "title": "Project Scripts",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "projectActions": [
        {
          "id": "projectActionsView",
          "name": "Project Scripts"
        },
        {
          "id": "suggestedActionsView",
          "name": "Suggested Actions"
        }
      ]
    },
    "commands": [
      {
        "command": "projectActions.runAction",
        "title": "Run Action",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.runSuggestion",
        "title": "Execute Suggested Script",
        "icon": "$(terminal)",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.addSuggestion",
        "title": "Add to Project Scripts",
        "icon": "$(add)",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.createConfig",
        "title": "Create Config File",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.openActionPicker",
        "title": "Run Action...",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.removeAction",
        "title": "Remove from Project Scripts",
        "icon": "$(trash)",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.runCuratedAction",
        "title": "Run Curated Action",
        "icon": "$(terminal)",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.runCuratedActionInNewTerminal",
        "title": "Run in New Terminal",
        "icon": "$(terminal)",
        "category": "Project Scripts"
      },
      {
        "command": "projectActions.runSuggestionInNewTerminal",
        "title": "Run in New Terminal",
        "icon": "$(terminal)",
        "category": "Project Scripts"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "projectActions.refresh",
          "when": "view == projectActionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "projectActions.runSuggestion",
          "when": "view == suggestedActionsView && viewItem == suggestion",
          "group": "inline@1"
        },
        {
          "command": "projectActions.addSuggestion",
          "when": "view == suggestedActionsView && viewItem == suggestion",
          "group": "inline@2"
        },
        {
          "command": "projectActions.runCuratedAction",
          "when": "view == projectActionsView && viewItem == curatedAction",
          "group": "inline@1"
        },
        {
          "command": "projectActions.removeAction",
          "when": "view == projectActionsView && viewItem == curatedAction",
          "group": "inline@2"
        },
        {
          "command": "projectActions.runCuratedActionInNewTerminal",
          "when": "view == projectActionsView && viewItem == curatedAction",
          "group": "navigation@1"
        },
        {
          "command": "projectActions.runSuggestionInNewTerminal",
          "when": "view == suggestedActionsView && viewItem == suggestion",
          "group": "navigation@1"
        }
      ],
      "editor/title": [
        {
          "command": "projectActions.openActionPicker",
          "group": "navigation",
          "icon": "$(terminal)",
          "when": "editorIsOpen"
        }
      ],
      "explorer/context": [
        {
          "command": "projectActions.openActionPicker",
          "group": "navigation",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "capabilities": {
      "untrustedWorkspaces": {
        "supported": false,
        "description": "Project Scripts requires workspace trust to run terminal commands safely."
      }
    }
  },
  "statusbar": {
    "id": "projectActions.status",
    "name": "Actions",
    "command": "projectActions.openActionPicker",
    "icon": "$(terminal)",
    "alignment": "right",
    "priority": 100
  },
  "jsonValidation": [
    {
      "fileMatch": ".vscode/project-actions.json",
      "url": "./resources/project-actions.schema.json"
    },
    {
      "fileMatch": ".cursor/project-actions.json",
      "url": "./resources/project-actions.schema.json"
    }
  ],
  "scripts": {
    "vscode:prepublish": "bun run bundle && bun run compile",
    "bundle": "bun build src/extension.ts --out=out/extension.js --target=node --external=vscode --external=fs --external=path --external=os",
    "compile": "bunx tsc -p ./",
    "watch": "bunx tsc -watch -p ./",
    "pretest": "bun run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.7.1",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "diff": "8.0.4"
  }
}
