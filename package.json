{
  "name": "project-actions",
  "displayName": "Project Actions",
  "description": "Execute project scripts from a sidebar panel.",
  "version": "0.3.6",
  "publisher": "your-publisher-id",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "scripts",
    "terminal",
    "commands",
    "sidebar",
    "productivity"
  ],
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-publisher-id/project-actions"
  },
  "license": "MIT",
  "activationEvents": [
    "onStartup"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectActions",
          "title": "Project Actions",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "projectActions": [
        {
          "id": "projectActionsView",
          "name": "Project Actions"
        },
        {
          "id": "suggestedActionsView",
          "name": "Suggested Actions"
        }
      ]
    },
    "commands": [
      {
        "command": "projectActions.runAction",
        "title": "Run Action",
        "category": "Project Actions"
      },
      {
        "command": "projectActions.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Project Actions"
      },
      {
        "command": "projectActions.runSuggestion",
        "title": "Execute Suggested Script",
        "icon": "$(terminal)",
        "category": "Project Actions"
      },
      {
        "command": "projectActions.addSuggestion",
        "title": "Add to Project Actions",
        "icon": "$(add)",
        "category": "Project Actions"
      },
      {
        "command": "projectActions.createConfig",
        "title": "Create Config File",
        "category": "Project Actions"
      },
      {
        "command": "projectActions.openActionPicker",
        "title": "Run Action...",
        "category": "Project Actions"
      },
      {
        "command": "projectActions.removeAction",
        "title": "Remove from Project Actions",
        "icon": "$(trash)",
        "category": "Project Actions"
      },
      {
        "command": "projectActions.runCuratedAction",
        "title": "Run Curated Action",
        "icon": "$(terminal)",
        "category": "Project Actions"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "projectActions.refresh",
          "when": "view == projectActionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "projectActions.runSuggestion",
          "when": "view == suggestedActionsView && viewItem == suggestion",
          "group": "inline@1"
        },
        {
          "command": "projectActions.addSuggestion",
          "when": "view == suggestedActionsView && viewItem == suggestion",
          "group": "inline@2"
        },
        {
          "command": "projectActions.runCuratedAction",
          "when": "view == projectActionsView && viewItem == curatedAction",
          "group": "inline@1"
        },
        {
          "command": "projectActions.removeAction",
          "when": "view == projectActionsView && viewItem == curatedAction",
          "group": "inline@2"
        }
      ],
      "editor/title": [
        {
          "command": "projectActions.openActionPicker",
          "group": "navigation",
          "icon": "$(terminal)",
          "when": "editorIsOpen"
        }
      ],
      "explorer/context": [
        {
          "command": "projectActions.openActionPicker",
          "group": "navigation",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "capabilities": {
      "untrustedWorkspaces": {
        "supported": false,
        "description": "Project Actions requires workspace trust to run terminal commands safely."
      }
    }
  },
  "statusbar": {
    "id": "projectActions.status",
    "name": "Actions",
    "command": "projectActions.openActionPicker",
    "icon": "$(terminal)",
    "alignment": "right",
    "priority": 100
  },
  "jsonValidation": [
    {
      "fileMatch": ".vscode/project-actions.json",
      "url": "./resources/project-actions.schema.json"
    }
  ],
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "bun run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.7.1",
    "mocha": "^10.0.0",
    "typescript": "^5.3.0"
  }
}
